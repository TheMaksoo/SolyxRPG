APP_NAME=Solyx
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://solyxrpg.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=solyxrpg
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Defaults to true whenever APP_ENV isn't "local" — leave unset unless you need to override that.
# SESSION_SECURE_COOKIE=true

SANCTUM_STATEFUL_DOMAINS=solyxrpg.test,localhost,localhost:*,127.0.0.1,127.0.0.1:*

# Socialite OAuth apps — create these in each provider's developer console,
# redirect URI: {APP_URL}/api/auth/{provider}/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudflare Turnstile — dash.cloudflare.com > Turnstile > add a widget for this domain.
# Leave both blank in local dev to skip verification entirely (register just works, no widget shown).
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
VITE_TURNSTILE_SITE_KEY="${TURNSTILE_SITE_KEY}"

# Stripe — from dashboard.stripe.com/apikeys and the webhook endpoint secret
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
